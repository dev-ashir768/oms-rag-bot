# ─── Gemini ────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash
GEMINI_EMBEDDING_MODEL=text-embedding-004

# ─── Server ────────────────────────────────────────────────
PORT=4000
NODE_ENV=production

# ─── CORS (comma-separated origins, or * for all) ──────────
ALLOWED_ORIGINS=*

# ─── RAG Settings ──────────────────────────────────────────
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
TOP_K_RESULTS=4

# ─── Rate Limiting ─────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=30

# ─── Bot Persona ───────────────────────────────────────────
BOT_NAME=Assistant
BOT_SYSTEM_PROMPT=You are a helpful assistant. Answer questions based only on the provided context. If the answer is not in the context, say you don't have that information. Be concise, friendly, and professional.
